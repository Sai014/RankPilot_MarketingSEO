# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# Groq AI
GROQ_API_KEY=your-groq-api-key

# ValueSERP
VALUESERP_API_KEY=your-valueserp-api-key

# Google PageSpeed Insights (required for reliable audits — avoids 429 rate limits)
GOOGLE_PAGESPEED_API_KEY=your-google-cloud-api-key

# ValueSERP batch delay during onboarding (seconds between keyword checks)
SERP_ONBOARD_DELAY_SEC=1

# CORS — comma-separated allowed origins (Vercel + local dev)
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Composio — Google Search Console OAuth + API
COMPOSIO_API_KEY=your-composio-api-key
COMPOSIO_GSC_AUTH_CONFIG_ID=ac_your-gsc-auth-config-id
COMPOSIO_GSC_TOOLKIT_VERSION=20260429_00
# Optional: override OAuth callback origin (defaults to first CORS_ORIGINS entry)
FRONTEND_URL=http://localhost:5173

# Optional overrides
GROQ_MODEL=llama-3.3-70b-versatile
LOG_LEVEL=INFO
PAGESPEED_ONBOARD_DELAY_SEC=2
